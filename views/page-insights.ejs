<!DOCTYPE html>
<html lang="en">
<%- include('components/head', { text: 'Insights' }) %>

    <body class="bg-[#154D41]">

        <!-- Content Wrapper -->
        <div class="relative z-20">

            <!-- Header Website -->
            <section>
                <%- include('components/header') %>
            </section>

            <!-- Main Content -->
            <section>
                <main>

                    <!-- Welcome Text -->
                    <header class="mt-25 mb-12 px-10">
                        <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-end justify-between gap-6">
                            <div>
                                <h1 class="text-[2em] md:text-[3em] font-extrabold text-white tracking-tight">
                                    The Knowledge Base
                                </h1>
                                <p class="max-w-2xl text-white/80 mt-3 text-[0.9em]">
                                    Dive into our collection of data-driven articles, deep dives, and technical
                                    explorations. From casual insights to strategic thinking - data that works for
                                    you.
                                </p>
                            </div>
                            <div class="flex flex-col gap-2 border-l border-white/10 pl-8">
                                <p class="text-[0.9em] md:text-[1em] uppercase tracking-widest text-white font-bold">
                                    Readers
                                </p>
                                <p class="text-[1em] md:text-[2em] font-bold text-white">
                                    14.2k
                                </p>
                            </div>
                        </div>
                    </header>

                    <!-- Featured Spotlight -->
                    <a href="#" class="px-10 mb-12 block group">
                        <div
                            class="max-w-6xl mx-auto relative rounded-3xl overflow-hidden cursor-pointer border border-white/10 shadow-2xl transition-all duration-500 group-hover:border-white/20">

                            <!-- Visual Placeholder Background with scaling -->
                            <div
                                class="absolute inset-0 bg-slate-900 group-hover:scale-110 transition-transform duration-1000 ease-out z-0">
                            </div>

                            <!-- Icon Layer -->
                            <div class="h-[300px] md:h-[450px] relative flex items-center justify-center z-5">
                                <svg class="w-32 h-32 text-white/5 transition-all duration-700 group-hover:scale-125 group-hover:text-white/10"
                                    fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z" />
                                </svg>
                            </div>

                            <!-- Better Gradient Overlay -->
                            <div
                                class="absolute inset-0 bg-gradient-to-t from-[#010C13] via-[#010C13]/60 to-transparent z-10">
                            </div>

                            <!-- Content Overlay -->
                            <div class="absolute bottom-0 left-0 p-8 md:p-12 z-20 w-full md:w-3/4 lg:w-2/3">
                                <span
                                    class="bg-[#8EF0DD] text-[#154D41] text-[0.5em] md:text-[0.8em] font-bold rounded-full uppercase tracking-widest inline-block shadow-sm px-3 py-1 mb-4">
                                    Featured Article
                                </span>
                                <h2
                                    class="text-[1.5em] md:text-[2em] font-extrabold text-white leading-tight tracking-tight mb-4 group-hover:text-[#8EF0DD] transition-colors duration-300">
                                    Quantum Computing: Deciphering the Future of Data Encryption
                                </h2>
                                <p
                                    class="text-white/80 text-[0.9em] md:text-[1em] line-clamp-2 md:line-clamp-none max-w-2xl bg-black/20 backdrop-blur-sm rounded-xl -ml-4 mb-8 p-4">
                                    How current cryptographic standards are being re-evaluated in the wake of modular
                                    quantum supremacy experiments across the globe.
                                </p>
                                <div class="flex items-center text-sm font-bold text-[#8EF0DD] group/link">
                                    <span
                                        class="border-b-2 border-[#8EF0DD]/30 group-hover/link:border-[#8EF0DD] transition-colors pb-1">
                                        Read Article
                                    </span>
                                    <svg class="w-5 h-5 group-hover/link:translate-x-2 transition-transform ml-2"
                                        fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                    </a>

                    <!-- Controls -->
                    <section class="mb-7 px-10">
                        <div class="max-w-6xl mx-auto flex flex-col md:flex-row gap-6 items-center justify-between">
                            <div class="flex gap-2 no-scrollbar overflow-x-auto w-full md:w-auto py-2">
                                <button
                                    class="px-5 py-2.5 bg-[#154D41] text-white rounded-full text-sm font-semibold whitespace-nowrap">
                                    All Insights</button>
                                <button
                                    class="bg-white/5 hover:bg-white/10 text-white/80 rounded-full text-[0.9em] font-medium transition-colors whitespace-nowrap border border-white/5 px-5 py-2.5">
                                    Technology
                                </button>
                                <button
                                    class="bg-white/5 hover:bg-white/10 text-white/80 rounded-full text-[0.9em] font-medium transition-colors whitespace-nowrap border border-white/5 px-5 py-2.5">
                                    Architecture
                                </button>
                                <button
                                    class="bg-white/5 hover:bg-white/10 text-white/80 rounded-full text-[0.9em] font-medium transition-colors whitespace-nowrap border border-white/5 px-5 py-2.5">
                                    Data Visuals
                                </button>
                            </div>

                            <div class="relative w-full md:w-72">
                                <input type="text" placeholder="Search library..."
                                    class="w-full bg-white/5 border border-white/10 rounded-full text-[0.9em] text-white/50 focus:outline-none focus:border-[#154D41] transition-all py-2.5 px-10">
                                <svg class="w-4 h-4 absolute left-4 top-3 text-white/50" fill="none"
                                    stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                </svg>
                            </div>
                        </div>
                    </section>

                    <!-- Content Articles (If Exist in Database) -->
                    <div class="mt-15 px-10 flex justify-center">
                        <div class="w-full max-w-6xl">
                            <% if (articles && articles.length> 0) { %>

                                <!-- Articles grid -->
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
                                    <% articles.forEach(article=> { %>
                                        <a href="/insights/<%= article.slug %>" class="group block">
                                            <div
                                                class="h-full flex flex-col bg-[#010C13] bg-opacity-5 backdrop-blur-sm rounded-lg hover:bg-opacity-10 border border-white border-opacity-10 hover:border-[#8EF0DD] hover:scale-110 overflow-hidden transition-all duration-300 p-6">
                                                <!-- Title -->
                                                <h3
                                                    class="text-white text-[1.2em] font-bold line-clamp-2 group-hover:text-[#8EF0DD] transition-colors mb-3">
                                                    <%= article.title %>
                                                </h3>

                                                <!-- Category -->
                                                <div class="mb-4">
                                                    <span
                                                        class="inline-block bg-[#8EF0DD] text-[#154D41] text-[0.9em] font-semibold rounded-full px-3 py-1">
                                                        <%= article.category || 'Article' %>
                                                    </span>
                                                </div>

                                                <!-- Sinopsis -->
                                                <p class="text-gray-300 text-[0.9em] line-clamp-3 flex-grow mb-4">
                                                    <%= article.excerpt || article.content.substring(0, 150) %>...
                                                </p>

                                                <!-- Meta Info -->
                                                <div
                                                    class="flex justify-between text-[0.7em] text-gray-400 border-t border-white border-opacity-10 pt-4">
                                                    <span>
                                                        <%= new Date(article.publishedAt ||
                                                            article.createdAt).toLocaleDateString('en-US', {
                                                            year: 'numeric' , month: 'short' , day: 'numeric' }) %>
                                                    </span>
                                                    <span>
                                                        <%= article.views || 0 %> views
                                                    </span>
                                                </div>
                                            </div>
                                        </a>
                                        <% }); %>
                                </div>

                                <!-- Pagination -->
                                <% if (pagination.pages> 1) { %>
                                    <div class="flex justify-center gap-2 mb-12">
                                        <% for (let i=1; i <=pagination.pages; i++) { %>
                                            <% if (i===pagination.page) { %>
                                                <button
                                                    class="rounded-lg bg-[#8EF0DD] text-[#154D41] font-semibold px-4 py-2">
                                                    <%= i %>
                                                </button>
                                                <% } else { %>
                                                    <a href="/insights?page=<%= i %>"
                                                        class="rounded-lg bg-white bg-opacity-10 text-white hover:bg-opacity-20 transition-all px-4 py-2">
                                                        <%= i %>
                                                    </a>
                                                    <% } %>
                                                        <% } %>
                                    </div>
                                    <% } %>

                                        <% } else { %>
                                            <div class="text-center py-12">
                                                <h2 class="text-white text-[2em]">No articles yet. Check back soon!</h2>
                                            </div>
                                            <% } %>
                        </div>
                    </div>
                </main>
            </section>

            <!-- Footer Website -->
            <section>
                <%- include('components/footer') %>
            </section>

        </div>

        <script src="script.js"></script>

    </body>

</html>
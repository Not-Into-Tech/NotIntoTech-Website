<!DOCTYPE html>
<html lang="en">
<%- include('components/head', { text: 'Data' }) %>

    <body class="bg-[#010C13]">

        <!-- Content Wrapper -->
        <div class="relative z-20">

            <!-- Header Website -->
            <section>
                <%- include('components/header') %>
            </section>

            <!-- Main Content -->
            <section>
                <main>
                    <!-- Welcome Text -->
                    <header class="mt-25 mb-12 px-10">
                        <div class="max-w-6xl mx-auto flex flex-col md:flex-row md:items-end justify-between gap-6">
                            <div>
                                <h1 class="text-[2em] md:text-[3em] font-extrabold text-white tracking-tight">
                                    The Datasets
                                </h1>
                                <p class="max-w-2xl text-white/80 mt-3 text-[0.9em]">
                                    Datasets compiled from internet using data mining scraping technique, you can use
                                    this datasets for your Artificial Intelligence or business analysis project.
                                </p>
                            </div>
                            <div class="flex flex-col gap-2 border-l border-white/10 pl-8">
                                <p class="text-[0.9em] md:text-[1em] uppercase tracking-widest text-white font-bold">
                                    Total Datasets
                                </p>
                                <p class="text-[1em] md:text-[2em] font-bold text-white">
                                    <%= datasets.length %>
                                </p>
                            </div>
                        </div>
                        <div class="mt-6 flex justify-center md:justify-start">
                            <%- include('components/button-white', {text:'Request Dataset', link:'/request'}) %>
                        </div>
                    </header>

                    <!-- Featured Spotlight -->
                    <% if (datasets && datasets.length> 0) { %>
                        <% const latestDataset=datasets[0]; %>
                            <a href="<%= latestDataset.file_url %>" target="_blank" rel="noopener noreferrer"
                                class="px-10 mb-12 block group">
                                <div
                                    class="max-w-6xl mx-auto h-[400px] md:h-[500px] relative rounded-3xl overflow-hidden cursor-pointer border border-white/10 shadow-2xl transition-all duration-500 group-hover:border-white/20">

                                    <!-- Visual Placeholder Background with scaling -->
                                    <div class="absolute inset-0 bg-slate-900 bg-cover bg-center group-hover:scale-110 transition-transform duration-1000 ease-out z-0"
                                        style="background-image: url('<%= latestDataset.cover_image_url %>');">
                                    </div>

                                    <!-- Better Gradient Overlay -->
                                    <div
                                        class="absolute inset-0 bg-gradient-to-t from-[#010C13] via-[#010C13]/80 to-transparent z-10">
                                    </div>

                                    <!-- Content Overlay -->
                                    <div class="absolute bottom-0 left-0 p-8 md:p-12 z-20 w-full md:w-3/4 lg:w-2/3">
                                        <span
                                            class="bg-[#8EF0DD] text-[#154D41] text-[0.5em] md:text-[0.8em] font-bold rounded-full uppercase tracking-widest inline-block shadow-sm px-3 py-1 mb-4">
                                            Latest Dataset
                                        </span>
                                        <h2
                                            class="text-[1.5em] md:text-[2em] font-extrabold text-white leading-tight tracking-tight mb-4 group-hover:text-[#8EF0DD] transition-colors duration-300">
                                            <%= latestDataset.title %>
                                        </h2>
                                        <p
                                            class="text-white/80 text-[0.9em] md:text-[1em] line-clamp-2 md:line-clamp-none max-w-2xl bg-black/40 backdrop-blur-sm rounded-xl -ml-4 mb-8 p-4">
                                            <%= latestDataset.description %>
                                        </p>
                                        <div class="flex items-center text-sm font-bold text-[#8EF0DD] group/link">
                                            <span
                                                class="border-b-2 border-[#8EF0DD]/30 group-hover/link:border-[#8EF0DD] transition-colors pb-1">
                                                Download Dataset
                                            </span>
                                            <svg class="w-5 h-5 group-hover/link:translate-x-2 transition-transform ml-2"
                                                fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                            </svg>
                                        </div>
                                    </div>
                                </div>
                            </a>
                            <% } %>

                                <!-- Dataset Cards -->
                                <section>
                                    <!-- Grid -->
                                    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 my-20 mx-10">
                                        <% if (datasets && datasets.length> 0) { %>
                                            <% datasets.forEach(function(dataset) { %>
                                                <!-- Card -->
                                                <div
                                                    class="group flex flex-col h-full border rounded-xl bg-neutral-900 border-neutral-700 hover:border-[#8EF0DD] hover:scale-105 transition-all duration-500">
                                                    <div
                                                        class="h-52 flex flex-col justify-center items-center overflow-clip bg-neutral-700 rounded-xl">
                                                        <img src="<%= dataset.cover_image_url || 'image-assets/dataset-cover/default-cover.jpg' %>"
                                                            alt="<%= dataset.title %> cover">
                                                    </div>
                                                    <div class="p-4 md:p-6">
                                                        <h3
                                                            class="text-xl font-semibold text-neutral-300 hover:text-white">
                                                            <%= dataset.title %>
                                                        </h3>
                                                        <p class="mt-3 text-neutral-500">
                                                            <%= dataset.description %>
                                                        </p>
                                                    </div>
                                                    <div
                                                        class="mt-auto flex border-t divide-x border-neutral-700 divide-neutral-700">
                                                        <a class="w-full py-3 px-4 inline-flex justify-center items-center gap-x-2 text-sm font-medium rounded-es-xl shadow-2xs focus:outline-hidden disabled:opacity-50 disabled:pointer-events-none bg-neutral-900 border-neutral-700 text-white hover:bg-neutral-800 focus:bg-neutral-800"
                                                            href="<%= dataset.file_url %>" target="_blank"
                                                            rel="noopener noreferrer">
                                                            Download Dataset
                                                        </a>
                                                    </div>
                                                </div>
                                                <!-- End Card -->
                                                <% }); %>
                                                    <% } else { %>
                                                        <div class="col-span-full text-center text-white/50">
                                                            <p>No datasets available right now.</p>
                                                        </div>
                                                        <% } %>
                                    </div>
                                </section>
                </main>
            </section>

            <!-- Footer Website -->
            <section>
                <%- include('components/footer') %>
            </section>

        </div>

        <script src="script.js"></script>

    </body>

</html>
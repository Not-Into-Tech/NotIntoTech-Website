<nav id="navbar"
    class="fixed top-0 z-50 flex w-full items-center justify-between px-3 py-3.5 md:px-5 transition-all duration-300">
    <div class="flex place-items-center gap-2">
        <a href="/">
            <img src="/image-assets/Not%20Into%20Tech%20White%20Logo.png" alt="Not Into Tech Logo" class="h-8">
        </a>
    </div>
    <div class="hidden items-center space-x-10 md:flex">
        <a class="transition text-white text-[1.1rem] no-underline font-medium hover:text-[#8EF0DD]"
            href="#chatbot">Chatbot</a>
        <a class="transition text-white text-[1.1rem] no-underline font-medium hover:text-[#8EF0DD]"
            href="#products">Product</a>
        <a class="transition text-white text-[1.1rem] no-underline font-medium hover:text-[#8EF0DD]"
            href="#partners">Partnership</a>
        <a class="bg-white/10 border border-white/20 rounded-full px-4 py-2 font-medium text-white text-[1.1rem] transition hover:opacity-90 active:scale-98"
            href="/profile">Contact Us</a>
    </div>
    <button id="menu-btn" class="transition active:scale-90 md:hidden">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white"
            stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu size-6.5"
            aria-hidden="true">
            <path d="M4 5h16"></path>
            <path d="M4 12h16"></path>
            <path d="M4 19h16"></path>
        </svg>
    </button>
</nav>

<div id="mobile-menu"
    class="fixed inset-0 z-50 flex flex-col items-center justify-center gap-6 bg-[#010C13]/20 text-white text-[1rem] font-medium backdrop-blur-2xl transition duration-300 md:hidden -translate-x-full">
    <a href="/">Home</a>
    <a href="/insights">Insights</a>
    <a href="/data">Data</a>
    <a href="/coming-soon">AI</a>
    <a class="bg-white/10 border border-white/20 rounded-full px-8 py-2.5 font-medium text-white transition hover:opacity-90 active:scale-98"
        href="/profile">Contact Us</a>
    <button id="close-btn"
        class="rounded-md p-2 bg-white/10 border border-white/20 transition hover:opacity-90 active:scale-50">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
            class="lucide lucide-x" aria-hidden="true">
            <path d="M18 6 6 18"></path>
            <path d="m6 6 12 12"></path>
        </svg>
    </button>
</div>

<script>
    // Navbar Mobile Responsive (DOM Manipulation)
    const navbar = document.getElementById("navbar");
    const mobileMenu = document.getElementById("mobile-menu");
    const menuBtn = document.getElementById("menu-btn");
    const closeBtn = document.getElementById("close-btn");
    document.addEventListener("DOMContentLoaded", () => {
        const navbar = document.getElementById("navbar");

        function handleScroll() {
            if (window.scrollY > 50) {
                navbar.classList.add("bg-white/15", "backdrop-blur-lg");
            } else {
                navbar.classList.remove("bg-white/15", "backdrop-blur-lg");
            }
        }

        window.addEventListener("scroll", handleScroll);
    });

    menuBtn.addEventListener("click", () => {
        mobileMenu.classList.remove("-translate-x-full");
        mobileMenu.classList.add("translate-x-0");
    });

    closeBtn.addEventListener("click", () => {
        mobileMenu.classList.remove("translate-x-0");
        mobileMenu.classList.add("-translate-x-full");
    });

    // Navbar scroll effect
    window.addEventListener('scroll', () => {
        const nav = document.getElementById('navbar');
        if (window.scrollY > 50) nav.classList.add('bg-[#010C13]');
        else nav.classList.remove('bg-[#010C13]');
    });
</script>
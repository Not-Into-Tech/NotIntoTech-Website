<div
    class="flex flex-col h-[400px] bg-white/80 backdrop-blur-xl rounded-2xl shadow-2xl overflow-hidden border border-slate-200">

    <div class="bg-[#010C13] p-4 text-white flex items-center justify-between">
        <div class="flex items-center gap-3">
            <div class="w-3 h-3 bg-[#154D41] rounded-full animate-pulse"></div>
            <span class="font-medium text-[0.8em] tracking-wide">NITE Bot: Advisor</span>
        </div>
    </div>

    <div id="chat-window" class="flex-grow overflow-y-auto space-y-4 text-[0.9em] bg-white/50 scroll-smooth p-6 ">
        <span id="status-dot" class="w-2 h-2 bg-[#154D41] rounded-full"></span>
        <div
            class="bg-[#154D41]/5 text-slate-700 rounded-lg rounded-tl-none border-l-2 border-[#154D41] max-w-[80%] p-4">
            Welcome! Let NITE’s chatbot assist you with technological transformation today.
        </div>
    </div>

    <form id="chat-form" class="bg-white border-t border-slate-100 flex gap-2 p-4">

        <input id="chat-input" type="text" placeholder="Inquire about proprietary LLMs..."
            class="flex-grow border border-slate-200 focus:outline-none focus:ring-1 focus:ring-[#154D41] px-4 py-2"
            autocomplete="off">

        <button type="submit" class="bg-[#154D41] p-3 rounded-xl hover:scale-105 transition-transform active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                class="w-5 h-5 text-white">
                <line x1="22" y1="2" x2="11" y2="13" />
                <polyline points="22 2 15 22 11 13 2 9 22 2" />
            </svg>
        </button>

    </form>

</div>
<!DOCTYPE html>
<html lang="en">
<%- include('components/head', { text: 'Insights' }) %>

    <body class="bg-[#154D41]">

        <!-- Content Wrapper -->
        <div class="relative z-20">

            <!-- Header Website -->
            <section class="p-[0.5em]">
                <%- include('components/header') %>
            </section>

            <!-- Main Content -->
            <section>
                <main class="px-10 flex justify-center">
                    <article class="w-full max-w-3xl py-12">

                        <!-- Article Header -->
                        <div class="mb-8">
                            <!-- Category -->
                            <div class="mb-4">
                                <span
                                    class="inline-block bg-[#8EF0DD] text-[#154D41] text-xs font-semibold px-3 py-1 rounded-full">
                                    <%= article.category || 'Article' %>
                                </span>
                            </div>

                            <!-- Title -->
                            <h1 class="text-white text-4xl lg:text-5xl font-bold mb-6 leading-tight">
                                <%= article.title %>
                            </h1>

                            <!-- Meta Info -->
                            <div
                                class="flex flex-wrap gap-4 text-gray-400 text-sm pb-6 border-b border-white border-opacity-10">
                                <span>By <strong class="text-white">
                                        <%= article.author || 'NITE Team' %>
                                    </strong></span>
                                <span>
                                    <%= new Date(article.publishedAt || article.createdAt).toLocaleDateString('en-US', {
                                        year: 'numeric' , month: 'long' , day: 'numeric' }) %>
                                </span>
                                <span id="viewCount">
                                    <%= article.views || 0 %> views
                                </span>
                            </div>
                        </div>

                        <!-- Article Content -->
                        <div class="prose prose-invert max-w-none mb-12">
                            <div class="text-white leading-relaxed text-base lg:text-lg">
                                <%- article.content %>
                            </div>
                        </div>

                        <!-- Dashboard Section -->
                        <% if (article.tableauUrl) { %>
                            <section class="my-16 border-t border-white border-opacity-10 pt-12">
                                <h2 class="text-white text-3xl font-bold mb-8">Data Visualization</h2>

                                <div
                                    class="mb-12 bg-[#010C13] bg-opacity-5 backdrop-blur-sm rounded-lg p-8 border border-white border-opacity-10">
                                    <!-- Tableau Embed -->
                                    <div class="bg-black bg-opacity-30 rounded-lg overflow-hidden min-h-[600px]">
                                        <tableau-viz id="tableau-dashboard" data-src="<%= article.tableauUrl %>"
                                            width="100%" height="600" style="display: block;">
                                        </tableau-viz>
                                    </div>
                                </div>
                            </section>
                            <% } %>

                                <!-- Tags Section -->
                                <% if (article.tags && article.tags.length> 0) { %>
                                    <section class="border-t border-white border-opacity-10 pt-8">
                                        <h4 class="text-white font-semibold mb-4">Tags</h4>
                                        <div class="flex flex-wrap gap-2">
                                            <% article.tags.forEach(tag=> { %>
                                                <a href="/insights?tag=<%= tag %>"
                                                    class="inline-block bg-[#010C13] bg-opacity-10 hover:bg-opacity-20 text-white px-4 py-2 rounded-full text-sm transition-all">
                                                    #<%= tag %>
                                                </a>
                                                <% }); %>
                                        </div>
                                    </section>
                                    <% } %>

                    </article>
                </main>
            </section>

            <!-- Footer Website -->
            <section>
                <%- include('components/footer') %>
            </section>

        </div>

        <script src="/script.js"></script>

    </body>

</html>
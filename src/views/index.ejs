<!DOCTYPE html>
<html lang="en">
<%- include('components/head', { text: 'Not Into Tech' }) %>

    <body class="bg-[#010C13]">

        <!-- Content Wrapper -->
        <div class="relative z-20">

            <!-- Header Website -->
            <section class="p-[0.5em]">
                <%- include('components/header-home') %>
            </section>

            <!-- Main Content -->
            <section>
                <main>

                    <!-- website main cta -->
                    <section id="home"
                        class="relative min-h-screen flex items-center justify-center bg-[#010C13] pt-20 mt-5">

                        <!-- background elements -->
                        <div class="absolute inset-0 z-0">
                            <!-- radial glow for depth -->
                            <div
                                class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#154D41]/20 rounded-full blur-[120px]">
                            </div>
                            <!-- grid pattern -->
                            <svg class="absolute inset-0 w-full h-full opacity-[0.03]"
                                xmlns="http://www.w3.org/2000/svg">
                                <defs>
                                    <pattern id="hero-grid" width="40" height="40" patternUnits="userSpaceOnUse">
                                        <path d="M 40 0 L 0 0 0 40" fill="none" stroke="white" stroke-width="1" />
                                    </pattern>
                                </defs>
                                <rect width="100%" height="100%" fill="url(#hero-grid)" />
                            </svg>
                        </div>

                        <div class="relative z-10 max-w-4xl mx-auto px-6 flex flex-col items-center text-center">
                            <!-- key message text -->
                            <div class="flex items-center gap-3 mb-8 animate-fade-in">
                                <p class="text-white/80 text-[0.9em] font-medium uppercase">
                                    Intelligence. Infrastructure. Impact.
                                </p>
                            </div>

                            <!-- main heading -->
                            <div class="relative inline-block">
                                <!-- floating icon 1 -->
                                <div class="absolute -top-12 -left-12 p-3 bg-white/5 backdrop-blur-md rounded-2xl border border-white/10 rotate-[-12deg] animate-bounce hidden md:block"
                                    style="animation-duration: 4s;">
                                    <i data-lucide="coffee" class="text-white w-6 h-6"></i>
                                </div>

                                <!-- floating icon 2 -->
                                <div
                                    class="absolute -bottom-4 -right-8 p-3 bg-white/5 backdrop-blur-md rounded-full border border-white/10 rotate-[15deg] animate-pulse hidden md:block">
                                    <i data-lucide="sparkles" class="text-white w-5 h-5"></i>
                                </div>

                                <h1
                                    class="text-[2em] md:text-[3em] text-white leading-tight font-bold tracking-tight mb-8">
                                    Hi
                                    <span class="text-[#154D41] italic">Not Into Tech</span>
                                    peeps
                                </h1>
                            </div>

                            <h3
                                class="text-white/80 text-[0.9em] md:text-[1em] max-w-2xl leading-relaxed font-light mb-12">
                                <span class="text-white font-medium">Not Into Tech? </span>
                                We are. We translate complex architectures into
                                <span class="text-white font-medium">high-stakes strategic clarity </span>
                                for the world's most ambitious leaders.
                            </h3>

                            <!-- action buttons -->
                            <div class="flex flex-col md:flex-row gap-5 w-full md:w-auto">
                                <%- include('components/button-white', {text:'Read insights', link:'/'}) %>
                                    <%- include('components/button-white', {text:'See products', link:'/'}) %>
                            </div>

                            <!-- Scroll Down Indicator -->
                            <div class="mt-24 animate-bounce opacity-30">
                                <i data-lucide="mouse-wheel" class="text-white w-6 h-6"></i>
                            </div>
                        </div>
                    </section>

                    <!-- list of company partners -->
                    <!-- NOT YET APPLICABLE -->

                    <!-- chatbot section -->
                    <section id="chatbot" class="max-w-7xl mx-auto px-6 py-24">
                        <div class="grid md:grid-cols-2 gap-16 items-center">

                            <div
                                class="flex flex-col h-[400px] bg-white/80 backdrop-blur-xl rounded-2xl shadow-2xl overflow-hidden border border-slate-200">
                                <div class="bg-[#010C13] p-4 text-white flex items-center justify-between">
                                    <div class="flex items-center gap-3">
                                        <div class="w-3 h-3 bg-[#154D41] rounded-full animate-pulse"></div>
                                        <span class="font-medium text-[0.8em] tracking-wide">NITE Bot: Advisor</span>
                                    </div>
                                    <i data-lucide="terminal" class="w-5 h-5 opacity-70"></i>
                                </div>
                                <div id="chat-window"
                                    class="flex-grow overflow-y-auto space-y-4 text-[0.9em] bg-white/50 scroll-smooth p-6 ">
                                    <div
                                        class="bg-[#154D41]/5 text-slate-700 rounded-lg rounded-tl-none border-l-2 border-[#154D41] max-w-[80%] p-4">
                                        Welcome! Let NITE’s chatbot assist you with technological transformation today.
                                    </div>
                                </div>
                                <div class="bg-white border-t border-slate-100 flex gap-2 p-4">
                                    <input id="chat-input" type="text" placeholder="Inquire about proprietary LLMs..."
                                        class="flex-grow border border-slate-200 focus:outline-none focus:ring-1 focus:ring-[#154D41] px-4 py-2">
                                    <button onclick="sendMessage()"
                                        class="bg-[#154D41] text-white p-2 hover:bg-[#010C13] transition-colors">
                                        <i data-lucide="send" class="w-5 h-5"></i>
                                    </button>
                                </div>
                            </div>

                            <div>
                                <h2 class="text-white text-[2em] mb-6">
                                    Automating <br>
                                    <span class="text-[#154D41]">Sovereign Advantage.</span>
                                </h2>
                                <h3 class="text-white text-[1em] mb-8">
                                    We don't just "deploy AI." We architect private, secure agentic systems that
                                    function as an extension of your board of directors, synthesizing data into
                                    actionable leverage.
                                </h3>
                                <ul class="space-y-4">
                                    <li class="flex items-start gap-3">
                                        <i data-lucide="shield-check" class="w-6 h-6 text-white flex-shrink-0"></i>
                                        <div>
                                            <span class="text-[0.9em] font-bold text-white">Zero-Trust
                                                Intelligence:</span>
                                            <p class="text-[0.9em] text-white">
                                                Your proprietary IP remains entirely isolated and local.
                                            </p>
                                        </div>
                                    </li>
                                    <li class="flex items-start gap-3">
                                        <i data-lucide="database" class="w-6 h-6 text-white flex-shrink-0"></i>
                                        <div>
                                            <span class="text-[0.9em] font-bold text-white">Alpha Generation:</span>
                                            <p class="text-[0.9em] text-white">
                                                Using predictive modeling to identify market inefficiencies.
                                            </p>
                                        </div>
                                    </li>
                                </ul>
                            </div>

                        </div>
                    </section>

                    <!-- product section -->
                    <section id="products" class="py-24">
                        <div class="max-w-7xl mx-auto px-6">

                            <div class="text-center max-w-2xl mx-auto mb-16">
                                <h2 class="text-[2em] text-white mb-4">
                                    The Architecture Suite
                                </h2>
                                <h3 class="text-white text-[1em]">
                                    Bespoke technical frameworks designed for the 1% of enterprises that define the
                                    market.
                                </h3>
                            </div>

                            <div class="grid md:grid-cols-3 gap-8">
                                <!-- product 1 -->
                                <div
                                    class="group border border-7 border-[#010C13] hover:border-[#154D41] hover:scale-105 transition-all bg-[#fcfcfc] relative overflow-hidden p-8">
                                    <div
                                        class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-100 transition-opacity">
                                        <i data-lucide="cpu" class="w-12 h-12 text-[#154D41]"></i>
                                    </div>
                                    <h3 class="text-[1em] font-bold text-[#010C13] mb-4">
                                        Insights
                                    </h3>
                                    <p class="text-slate-500 text-[0.9em] leading-relaxed mb-6">
                                        Tech industry data driven insights that transforms fragmented information into
                                        actionable insights.
                                    </p>
                                    <a href="/insights"
                                        class="text-[#154D41] text-[0.8em] font-bold tracking-widest uppercase flex items-center gap-2 hover:text-[#154D41]/50 transition-all">
                                        View Insights <i data-lucide="chevron-right" class="w-4 h-4"></i>
                                    </a>
                                </div>
                                <!-- product 2 -->
                                <div
                                    class="group border border-7 border-[#010C13] hover:border-[#154D41] hover:scale-105 transition-all bg-[#fcfcfc] relative overflow-hidden p-8">
                                    <div
                                        class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-100 transition-opacity">
                                        <i data-lucide="bar-chart-3" class="w-12 h-12 text-[#154D41]"></i>
                                    </div>
                                    <h3 class="text-[1em] font-bold text-[#010C13] mb-4">
                                        Dataset
                                    </h3>
                                    <p class="text-slate-500 text-[0.9em] leading-relaxed mb-6">
                                        Collection of datasets with various categories to help insights generation and
                                        decision making for a corporates or personal project.
                                    </p>
                                    <a href="/dataset"
                                        class="text-[#154D41] text-[0.8em] font-bold tracking-widest uppercase flex items-center gap-2 hover:text-[#154D41]/50 transition-all">
                                        View Dataset <i data-lucide="chevron-right" class="w-4 h-4"></i>
                                    </a>
                                </div>
                                <!-- product 3 -->
                                <div
                                    class="group border border-7 border-[#010C13] hover:border-[#154D41] hover:scale-105 transition-all bg-[#fcfcfc] relative overflow-hidden p-8">
                                    <div
                                        class="absolute top-0 right-0 p-4 opacity-10 group-hover:opacity-100 transition-opacity">
                                        <i data-lucide="layers" class="w-12 h-12 text-[#154D41]"></i>
                                    </div>
                                    <h3 class="text-[1em] font-bold text-[#010C13] mb-4">
                                        Artificial Intelligence
                                    </h3>
                                    <p class="text-slate-500 text-[0.9em] leading-relaxed mb-6">
                                        Latest artificial intelligence developed by us including agentic AI, generative
                                        AI, and many more.
                                    </p>
                                    <a href="/ai"
                                        class="text-[#154D41] text-[0.8em] font-bold tracking-widest uppercase flex items-center gap-2 hover:text-[#154D41]/50 transition-all">
                                        View AI <i data-lucide="chevron-right" class="w-4 h-4"></i>
                                    </a>
                                </div>
                            </div>

                        </div>
                    </section>

                    <!-- partnership section -->
                    <section id="partners"
                        class="bg-gradient-to-br from-[#154D41] to-[#010C13] text-white overflow-hidden relative py-24">

                        <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none">
                            <svg viewBox="0 0 100 100" class="w-full h-full">
                                <defs>
                                    <pattern id="grid" width="10" height="10" patternUnits="userSpaceOnUse">
                                        <path d="M 10 0 L 0 0 0 10" fill="none" stroke="white" stroke-width="0.5" />
                                    </pattern>
                                </defs>
                                <rect width="100" height="100" fill="url(#grid)" />
                            </svg>
                        </div>

                        <div class="max-w-7xl mx-auto relative z-10 px-6">
                            <div class="max-w-3xl">
                                <h2 class="text-[2em] mb-8">
                                    Exclusive Strategic Alliances.
                                </h2>
                                <p class="text-slate-300 text-[0.9em] leading-relaxed mb-12">
                                    We do not "accept clients." We form alliances with organizations that recognize the
                                    terminal risks of technical stagnation.
                                </p>
                                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-12 mb-12">
                                    <div class="pl-6">
                                        <p class="font-bold text-[0.9em] mb-2">Early Access</p>
                                        <p class="text-slate-400 text-[0.9em]">
                                            Get early access to our latest research and data analysis.
                                        </p>
                                    </div>
                                    <div class="pl-6">
                                        <p class="font-bold text-[0.9em] mb-2">Brainstorm Session</p>
                                        <p class="text-slate-400 text-[0.9em]">
                                            Joint ventures designed to pioneer the next generation of industry
                                            standards.
                                        </p>
                                    </div>
                                    <div class="pl-6">
                                        <p class="font-bold text-[0.9em] mb-2">Strategy Transformation</p>
                                        <p class="text-slate-400 text-[0.9em]">
                                            Total modernization of the digital core with a focus on long-term
                                            sustainability.
                                        </p>
                                    </div>
                                </div>
                                <a href="/profile">
                                    <%- include('components/button-white', {text:'Become partner', link:'/profile'}) %>
                                </a>
                            </div>
                        </div>
                    </section>

                    <!-- Contact & Feedback Form -->
                    <section class="py-24">
                        <div class="max-w-7xl mx-auto px-6">

                            <div class="grid md:grid-cols-2 gap-16">
                                <div>
                                    <h2 class="text-[2em] text-white mb-6">
                                        Discretion &
                                        <br><span class="text-[#154D41]">Precision</span>
                                    </h2>
                                    <h3 class="text-white/80 text-[1em] mb-8">
                                        We value precise feedback. Whether you are a client, partner, or researcher,
                                        your insights drive our technical evolution.
                                    </h3>
                                    <div class="space-y-6">

                                        <div class="flex items-center gap-4">
                                            <div class="w-12 h-12 bg-slate-50 flex items-center justify-center">
                                                <i data-lucide="mail" class="text-[#154D41] w-6 h-6"></i>
                                            </div>
                                            <div>
                                                <div
                                                    class="text-[0.9em] uppercase text-slate-400 font-bold tracking-widest">
                                                    Inquiries
                                                </div>
                                                <div class="font-medium text-white/80">
                                                    notintotech@gmail.com
                                                </div>
                                            </div>
                                        </div>

                                        <div class="flex items-center gap-4">
                                            <div class="w-12 h-12 bg-slate-50 flex items-center justify-center">
                                                <i data-lucide="globe" class="text-[#154D41] w-6 h-6"></i>
                                            </div>
                                            <div>
                                                <div
                                                    class="text-[0.9em] uppercase text-slate-400 font-bold tracking-widest">
                                                    Presence
                                                </div>
                                                <div class="font-medium text-white/80">Surabaya • Indonesia
                                                </div>
                                            </div>
                                        </div>

                                    </div>
                                </div>

                                <div class="bg-[#154D41] p-10 border border-slate-100">
                                    <%- include('components/feedback-form') %>
                                </div>
                            </div>

                        </div>
                    </section>
                </main>
            </section>

            <!-- Footer Website -->
            <section>
                <%- include('components/footer') %>
            </section>

        </div>

        <script src="script.js"></script>

    </body>

</html>